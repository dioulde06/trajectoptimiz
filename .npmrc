# Désactive le hoisting agressif pour garder un node_modules propre
shamefully-hoist=false

# Évite les erreurs de peer deps avec Next.js / tRPC / React
strict-peer-dependencies=false

# Résolution automatique des peer deps manquantes
auto-install-peers=true

# Lien symbolique des packages du workspace
link-workspace-packages=true

# Désactive la vérification d'âge minimum des releases (sinon les packages
# récents comme @anthropic-ai/sdk@0.101.0 sont bloqués en CI pendant 72h)
minimum-release-age=0
